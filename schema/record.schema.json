{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/HautevilleHouse/formal-record/blob/main/schema/record.schema.json",
  "title": "Conjecture record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_id",
    "title",
    "authors",
    "source",
    "crosswalk",
    "statement",
    "settlement",
    "verification",
    "review",
    "rights",
    "provenance"
  ],
  "properties": {
    "schema_version": {"const": "1.0"},
    "record_id": {"type": "string", "pattern": "^cr_[0-9a-f]{24}$"},
    "title": {"type": "string", "minLength": 1},
    "authors": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "identifier", "url"],
      "properties": {
        "kind": {"const": "arxiv"},
        "identifier": {"type": "string", "pattern": "^\\d{4}\\.\\d{4,5}v\\d+$"},
        "url": {"type": "string", "format": "uri"}
      }
    },
    "crosswalk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["openconjecture_ids", "formal_conjectures_paths"],
      "properties": {
        "openconjecture_ids": {"type": "array", "items": {"type": "integer", "minimum": 0}, "uniqueItems": true},
        "formal_conjectures_paths": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
      }
    },
    "statement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "location", "content_sha256"],
      "properties": {
        "label": {"type": "string"},
        "location": {"type": ["string", "null"]},
        "content_sha256": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"}
      }
    },
    "settlement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "result_type", "summary", "packet_url"],
      "properties": {
        "status": {"enum": ["open", "attacked", "partial", "proved", "disproved", "statement_defective", "superseded"]},
        "result_type": {"enum": ["none", "proof", "counterexample", "classification", "computer_assisted_resolution", "statement_correction", "mixed"]},
        "summary": {"type": "string"},
        "packet_url": {"type": "string", "format": "uri"}
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence", "routes"],
      "properties": {
        "evidence": {"type": "string"},
        "routes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "command"],
            "properties": {
              "kind": {"enum": ["python", "lean", "cpp", "certificate", "manual", "symbolic"]},
              "command": {"type": "string", "minLength": 1}
            }
          }
        }
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {"status": {"enum": ["unreviewed", "internal_replay", "external_reviewed", "author_confirmed"]}}
    },
    "rights": {
      "type": "object",
      "additionalProperties": false,
      "required": ["record_notice", "upstream_license_url"],
      "properties": {
        "record_notice": {"type": "string"},
        "upstream_license_url": {"type": ["string", "null"]}
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_repository", "source_revision", "source_identity_path", "source_identity_sha256"],
      "properties": {
        "source_repository": {"type": "string", "format": "uri"},
        "source_revision": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "source_identity_path": {"type": "string"},
        "source_identity_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
      }
    }
  }
}
